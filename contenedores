#!/bin/bash

# ==============================================================================
# Script: contenedores (v2.19)
# Proposito: Gestionar contenedores Distrobox con HOME aislado en ~/Contenedores distrobox/
# ==============================================================================

# Captura de Ctrl+C
trap 'echo "[!] Operacion cancelada."; exit 1' INT

# ------------------------------------------------------------------------------
# Catalogo de Imagenes
# ------------------------------------------------------------------------------
CATALOGO=(
    "Ubuntu LTS (ultima version estable)|ubuntu:latest"
    "Debian Stable (ultima version estable)|debian:stable"
    "Fedora (ultima version)|fedora:latest"
    "Arch Linux (Rolling Release)|archlinux:latest"
)

BASE_DIR="$HOME/Contenedores distrobox"
LOG_FILE="$BASE_DIR/.log"
MAX_LOG_LINES=500
mkdir -p "$BASE_DIR"

# ------------------------------------------------------------------------------
# Funciones auxiliares
# ------------------------------------------------------------------------------
log() {
    echo "[$(date '+%Y-%m-%d %H:%M')] $*" >> "$LOG_FILE"
}

contenedores_gestionados() {
    local todos gestionados=() nombre
    todos=$(distrobox list --no-color 2>/dev/null | awk -F'|' 'NR>1 {gsub(/^ +| +$/, "", $2); if ($2 ~ /^[a-zA-Z0-9_-]+$/) print $2}')
    while IFS= read -r nombre; do
        if [[ -n "$nombre" && -d "$BASE_DIR/$nombre" ]]; then
            gestionados+=("$nombre")
        fi
    done <<< "$todos"
    if [ ${#gestionados[@]} -gt 0 ]; then
        printf '%s\n' "${gestionados[@]}"
    fi
}

# ------------------------------------------------------------------------------
# 0. Verificacion de dependencias
# ------------------------------------------------------------------------------
verificar_dependencias() {
    local falta=0
    for cmd in distrobox podman; do
        if ! command -v "$cmd" > /dev/null 2>&1; then
            echo "[-] Dependencia no encontrada: $cmd"
            falta=1
        fi
    done
    if [ "$falta" -eq 1 ]; then
        exit 1
    fi
}

# ------------------------------------------------------------------------------
# 1. Crear contenedor
# ------------------------------------------------------------------------------
crear_contenedor() {
    local BOX_NAME TARGET_DIR EXISTE_BOX TOTAL SELECTED_IMAGE SELECTED_NAME
    local SELECTED_ENTRY choice NAME confirm carpetas entrar

    echo ""
    echo "  Se creara un contenedor con las siguientes caracteristicas:"
    echo ""
    echo "  - Entorno Linux aislado del sistema anfitrion"
    echo "  - HOME propio en: $BASE_DIR/<nombre_del_contenedor>"
    echo "  - Acceso a la red del anfitrion"
    echo "  - Acceso al sistema de archivos del anfitrion"
    echo "  - Gestionado exclusivamente por este script"
    echo ""

    printf "  Nombre para el nuevo contenedor (0 para volver): "
    read -r BOX_NAME

    [ "$BOX_NAME" = "0" ] && return

    if [ -z "$BOX_NAME" ]; then
        echo ""
        echo "  [-] El nombre es obligatorio."
        return
    fi

    case "$BOX_NAME" in
        *[!a-zA-Z0-9_-]*)
            echo ""
            echo "  [-] Solo se permiten letras, numeros, guiones y guiones bajos."
            return
            ;;
    esac

    TARGET_DIR="$BASE_DIR/$BOX_NAME"
    EXISTE_BOX=$(distrobox list --no-color 2>/dev/null | awk -F'|' 'NR>1 {gsub(/^ +| +$/, "", $2); print $2}' | grep -Fx "$BOX_NAME")

    if [ -d "$TARGET_DIR" ] || [ -n "$EXISTE_BOX" ]; then
        echo ""
        echo "  [!] Ya existe un contenedor o directorio con el nombre '$BOX_NAME'."
        echo "      Usa la opcion 5 para eliminarlo antes de recrearlo."
        return
    fi

    echo ""
    echo "  Selecciona la distribucion que quieres usar:"
    echo ""
    TOTAL=${#CATALOGO[@]}
    for i in "${!CATALOGO[@]}"; do
        NAME=$(echo "${CATALOGO[$i]}" | cut -d'|' -f1)
        printf "  %d) %s\n" "$((i+1))" "$NAME"
    done
    echo "  0) Volver al menu"
    echo ""

    while true; do
        printf "  Opcion [0-%d]: " "$TOTAL"
        read -r choice
        if [ "$choice" = "0" ]; then
            return
        elif echo "$choice" | grep -qE '^[0-9]+$' && [ "$choice" -ge 1 ] && [ "$choice" -le "$TOTAL" ]; then
            SELECTED_ENTRY="${CATALOGO[$((choice-1))]}"
            SELECTED_NAME=$(echo "$SELECTED_ENTRY" | cut -d'|' -f1)
            SELECTED_IMAGE=$(echo "$SELECTED_ENTRY" | cut -d'|' -f2)
            break
        else
            echo "  [-] Opcion invalida."
        fi
    done

    echo ""
    echo "  Revisa el resumen antes de continuar:"
    echo ""
    echo "  Nombre  : $BOX_NAME"
    echo "  Sistema : $SELECTED_NAME"
    echo "  Imagen  : $SELECTED_IMAGE"
    echo "  Home    : $TARGET_DIR"
    echo ""

    printf "  Confirmar creacion? [s/N]: "
    read -r confirm
    if [ "$confirm" != "s" ] && [ "$confirm" != "S" ]; then
        echo "  Cancelado."
        return
    fi

    echo ""
    echo "  [+] Iniciando descarga de la imagen '$SELECTED_IMAGE'..."
    echo "      Esto puede tardar varios minutos dependiendo de tu conexion."
    echo "      El sistema esta trabajando, por favor espera."
    echo ""

    if distrobox create --name "$BOX_NAME" --image "$SELECTED_IMAGE" --home "$TARGET_DIR"; then
        log "CREADO: $BOX_NAME | imagen: $SELECTED_IMAGE | home: $TARGET_DIR"
        echo ""
        echo "  [+] Contenedor '$BOX_NAME' creado correctamente."
    else
        echo ""
        echo "  [-] Error al crear el contenedor. Revisa la conexion o el nombre de la imagen."
        return
    fi

    echo ""
    printf "  Crear las carpetas estandar del HOME (Descargas, Documentos, etc.)? [s/N]: "
    read -r carpetas
    if [ "$carpetas" = "s" ] || [ "$carpetas" = "S" ]; then
        echo "  [+] Creando carpetas estandar..."
        distrobox enter "$BOX_NAME" -- sh -c 'command -v xdg-user-dirs-update && xdg-user-dirs-update' \
            && echo "  [+] Carpetas creadas correctamente." \
            || echo "  [!] xdg-user-dirs-update no esta disponible en esta imagen."
    fi

    echo ""
    printf "  Entrar al contenedor ahora? [s/N]: "
    read -r entrar
    if [ "$entrar" = "s" ] || [ "$entrar" = "S" ]; then
        distrobox enter "$BOX_NAME"
    fi
}

# ------------------------------------------------------------------------------
# 2. Listar contenedores
# ------------------------------------------------------------------------------
listar_contenedores() {
    echo ""
    printf "  %-20s %s\n" "NOMBRE" "ESTADO"
    echo ""
    distrobox list --no-color | awk -F'|' 'NR>1 {
        nombre = $2
        estado = $3
        gsub(/^ +| +$/, "", nombre)
        gsub(/^ +| +$/, "", estado)
        if (nombre ~ /^[a-zA-Z0-9_-]+$/)
            printf "  %-20s %s\n", nombre, estado
    }'
    echo ""
}

# ------------------------------------------------------------------------------
# 3. Entrar a un contenedor
# ------------------------------------------------------------------------------
entrar_contenedor() {
    local BOXES LISTA=() linea choice BOX_NAME

    BOXES=$(contenedores_gestionados)
    if [ -z "$BOXES" ]; then
        echo ""
        echo "  [!] No hay contenedores disponibles. Crea uno primero con la opcion 1."
        return
    fi

    while IFS= read -r linea; do
        [ -n "$linea" ] && LISTA+=("$linea")
    done <<< "$BOXES"

    echo ""
    echo "  Selecciona el contenedor al que quieres entrar:"
    echo ""
    for i in "${!LISTA[@]}"; do
        printf "  %d) %s\n" "$((i+1))" "${LISTA[$i]}"
    done
    echo "  0) Volver al menu"
    echo ""

    while true; do
        printf "  Opcion [0-%d]: " "${#LISTA[@]}"
        read -r choice
        if [ "$choice" = "0" ]; then
            return
        elif echo "$choice" | grep -qE '^[0-9]+$' && [ "$choice" -ge 1 ] && [ "$choice" -le "${#LISTA[@]}" ]; then
            break
        else
            echo "  [-] Opcion invalida."
        fi
    done

    BOX_NAME="${LISTA[$((choice-1))]}"
    log "ACCESO: $BOX_NAME"
    distrobox enter "$BOX_NAME"
}

# ------------------------------------------------------------------------------
# 4. Apagar contenedor
# ------------------------------------------------------------------------------
apagar_contenedor() {
    local BOXES LISTA=() linea choice BOX_NAME

    BOXES=$(distrobox list --no-color 2>/dev/null | awk -F'|' 'NR>1 {
        nombre = $2
        estado = $3
        gsub(/^ +| +$/, "", nombre)
        gsub(/^ +| +$/, "", estado)
        if (nombre ~ /^[a-zA-Z0-9_-]+$/ && estado ~ /^Up/)
            print nombre
    }')

    if [ -z "$BOXES" ]; then
        echo ""
        echo "  [!] No hay contenedores encendidos en este momento."
        return
    fi

    while IFS= read -r linea; do
        [ -n "$linea" ] && LISTA+=("$linea")
    done <<< "$BOXES"

    echo ""
    echo "  Selecciona el contenedor que quieres apagar:"
    echo ""
    for i in "${!LISTA[@]}"; do
        printf "  %d) %s\n" "$((i+1))" "${LISTA[$i]}"
    done
    echo "  0) Volver al menu"
    echo ""

    while true; do
        printf "  Opcion [0-%d]: " "${#LISTA[@]}"
        read -r choice
        if [ "$choice" = "0" ]; then
            return
        elif echo "$choice" | grep -qE '^[0-9]+$' && [ "$choice" -ge 1 ] && [ "$choice" -le "${#LISTA[@]}" ]; then
            break
        else
            echo "  [-] Opcion invalida."
        fi
    done

    BOX_NAME="${LISTA[$((choice-1))]}"
    echo ""
    echo "  [+] Apagando '$BOX_NAME'..."
    distrobox stop --yes "$BOX_NAME"
    log "APAGADO: $BOX_NAME"
    echo "  [+] '$BOX_NAME' apagado correctamente."
    echo ""
}

# ------------------------------------------------------------------------------
# 5. Eliminar contenedor
# ------------------------------------------------------------------------------
eliminar_contenedor() {
    local BOXES LISTA=() linea choice BOX_NAME TARGET_DIR SHORTCUTS confirmacion

    BOXES=$(contenedores_gestionados)
    if [ -z "$BOXES" ]; then
        echo ""
        echo "  [!] No hay contenedores para eliminar."
        return
    fi

    while IFS= read -r linea; do
        [ -n "$linea" ] && LISTA+=("$linea")
    done <<< "$BOXES"

    echo ""
    echo "  Selecciona el contenedor que quieres eliminar:"
    echo ""
    for i in "${!LISTA[@]}"; do
        printf "  %d) %s\n" "$((i+1))" "${LISTA[$i]}"
    done
    echo "  0) Volver al menu"
    echo ""

    while true; do
        printf "  Opcion [0-%d]: " "${#LISTA[@]}"
        read -r choice
        if [ "$choice" = "0" ]; then
            return
        elif echo "$choice" | grep -qE '^[0-9]+$' && [ "$choice" -ge 1 ] && [ "$choice" -le "${#LISTA[@]}" ]; then
            break
        else
            echo "  [-] Opcion invalida."
        fi
    done

    BOX_NAME="${LISTA[$((choice-1))]}"
    TARGET_DIR="$BASE_DIR/$BOX_NAME"
    SHORTCUTS=$(find ~/.local/share/applications -name "*${BOX_NAME}*" 2>/dev/null)

    echo ""
    echo "  ADVERTENCIA: Esta accion es completamente irreversible."
    echo ""
    echo "  Se eliminaran permanentemente:"
    echo "    - Contenedor Distrobox : $BOX_NAME"
    [ -d "$TARGET_DIR" ] && echo "    - Directorio HOME      : $TARGET_DIR"
    [ -n "$SHORTCUTS" ] && echo "    - Accesos directos (.desktop) en el menu del sistema"
    echo ""
    echo "  Para confirmar, escribe el nombre exacto del contenedor:"
    echo ""

    printf "  Nombre: "
    read -r confirmacion
    if [ "$confirmacion" != "$BOX_NAME" ]; then
        echo "  Cancelado. El nombre no coincide."
        return
    fi

    echo ""
    echo "  [+] Eliminando contenedor..."
    distrobox rm --force "$BOX_NAME" 2>/dev/null

    if [ -d "$TARGET_DIR" ]; then
        echo "  [+] Eliminando directorio HOME..."
        rm -rf "$TARGET_DIR"
    fi

    if [ -n "$SHORTCUTS" ]; then
        echo "  [+] Eliminando accesos directos huerfanos..."
        find ~/.local/share/applications -name "*${BOX_NAME}*" -delete
    fi

    log "ELIMINADO: $BOX_NAME | home: $TARGET_DIR"
    echo ""
    echo "  [+] '$BOX_NAME' eliminado completamente, sin rastro."
    echo ""
}

# ------------------------------------------------------------------------------
# Menu principal
# ------------------------------------------------------------------------------
menu_principal() {
    local opcion
    while true; do
        echo ""
        echo "  Gestion de Contenedores Distrobox"
        echo ""
        echo "  1) Crear nuevo contenedor"
        echo "  2) Listar contenedores existentes"
        echo "  3) Entrar a un contenedor"
        echo "  4) Apagar contenedor"
        echo "  5) Eliminar contenedor"
        echo "  6) Salir"
        echo ""
        printf "  Opcion [1-6]: "
        read -r opcion

        case "$opcion" in
            1) crear_contenedor ;;
            2) listar_contenedores ;;
            3) entrar_contenedor ;;
            4) apagar_contenedor ;;
            5) eliminar_contenedor ;;
            6) echo "  Hasta luego."; exit 0 ;;
            *) echo "  [-] Opcion invalida." ;;
        esac
    done
}

# ------------------------------------------------------------------------------
# Punto de entrada
# ------------------------------------------------------------------------------
verificar_dependencias
menu_principal
