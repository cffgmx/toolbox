#!/bin/bash
# Nombre: sincronizar
# Perfil: Seguridad Industrial Máxima

set -eo pipefail

# ──────────────────────────────────────────────────────────────────
# 0. CONFIGURACIÓN
# ──────────────────────────────────────────────────────────────────
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
LOCKFILE="$CACHE_DIR/sincronizar.lock"
LOG_FILE="$CACHE_DIR/sincronizar.log"
LOG_MAX_LINES=2000
MARGIN=5
RETRIES=3
SLEEP_RETRY=5

mkdir -p "$CACHE_DIR"

# ──────────────────────────────────────────────────────────────────
# 1. DEPENDENCIAS
# ──────────────────────────────────────────────────────────────────
for cmd in rclone rsync flock xdg-user-dir mountpoint du df; do
    command -v "$cmd" &>/dev/null || {
        echo "Error: dependencia faltante: $cmd"
        exit 1
    }
done

# ──────────────────────────────────────────────────────────────────
# 2. ROTACIÓN DE LOG
# ──────────────────────────────────────────────────────────────────
if [[ -f "$LOG_FILE" ]]; then
    tail -n "$LOG_MAX_LINES" "$LOG_FILE" > "${LOG_FILE}.tmp" \
        && mv "${LOG_FILE}.tmp" "$LOG_FILE"
fi

# ──────────────────────────────────────────────────────────────────
# 3. FUNCIONES DE EJECUCIÓN
# ──────────────────────────────────────────────────────────────────

spinner() {
    local pid=$1
    local spinstr='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf '  Sincronizando... %s\r' "${spinstr:$i:1}"
        i=$(( (i + 1) % ${#spinstr} ))
        sleep 0.15
    done
    printf '%-72s\r' ""
}

run_rclone() {
    local tmp exit_code=0
    tmp=$(mktemp)

    if [[ -t 1 ]]; then
        rclone sync "$dir" "gdrive:thinkpad" \
            --drive-use-trash \
            --fast-list \
            --exclude ".git/**" \
            --stats-one-line \
            --stats 2s \
            > "$tmp" 2>&1 &
        local pid=$!
        spinner "$pid"
        wait "$pid" || exit_code=$?

        local summary
        summary=$(tr '\r' '\n' < "$tmp" \
            | sed 's/\x1b\[[0-9;]*[A-Za-z]//g' \
            | grep -i "Transferred:" \
            | tail -1)
        [[ -n "$summary" ]] && echo "  $summary"

        tr '\r' '\n' < "$tmp" \
            | sed 's/\x1b\[[0-9;]*[A-Za-z]//g' \
            | grep -v '^$' >> "$LOG_FILE"

        rm -f "$tmp"
    else
        rclone sync "$dir" "gdrive:thinkpad" \
            --drive-use-trash \
            --fast-list \
            --exclude ".git/**" \
            --quiet \
            >> "$LOG_FILE" 2>&1 || exit_code=$?
    fi

    return "$exit_code"
}

run_rsync() {
    local tmp exit_code=0
    tmp=$(mktemp)

    if [[ -t 1 ]]; then
        rsync -a --delete --exclude ".git/" \
            --info=progress2 --stats "$dir" "$ssd/" \
            > "$tmp" 2>&1 &
        local pid=$!
        spinner "$pid"
        wait "$pid" || exit_code=$?

        local summary
        summary=$(tr '\r' '\n' < "$tmp" \
            | grep "%" \
            | tail -1 \
            | tr -d '\r')
        [[ -n "$summary" ]] && echo "  $summary"

        tr '\r' '\n' < "$tmp" \
            | grep -v '^$' >> "$LOG_FILE"

        rm -f "$tmp"
    else
        rsync -a --delete --exclude ".git/" \
            --stats "$dir" "$ssd/" \
            >> "$LOG_FILE" 2>&1 || exit_code=$?
    fi

    return "$exit_code"
}

# ──────────────────────────────────────────────────────────────────
# 4. EXCLUSIVIDAD (LOCKFILE)
# ──────────────────────────────────────────────────────────────────
exec 9>"$LOCKFILE"
if ! flock -n 9; then
    echo "Aviso: ya existe una sincronización en curso."
    echo "Para seguir su progreso, consulte el archivo de registro en:"
    echo "  $LOG_FILE"
    exit 0
fi

trap 'echo "[$(date +"%F %T")] Proceso interrumpido abruptamente." >> "$LOG_FILE"; rm -f "$LOCKFILE"' EXIT INT TERM

# ──────────────────────────────────────────────────────────────────
# 5. DIRECTORIOS Y VALIDACIÓN DEL ORIGEN
# ──────────────────────────────────────────────────────────────────
dir=$(xdg-user-dir DOCUMENTS 2>/dev/null || echo "$HOME/Documentos")
dir="${dir%/}/"
ssd="/run/media/$USER/Respaldo"

if [[ ! -d "$dir" ]]; then
    echo "Error: el directorio de origen no existe ($dir)."
    exit 1
fi

if [[ -z "$(find "$dir" -mindepth 1 -print -quit)" ]]; then
    echo "Error: el directorio de origen está vacío ($dir)."
    echo "Se ha cancelado la operación para proteger el respaldo existente."
    exit 1
fi

# ──────────────────────────────────────────────────────────────────
# 6. INICIO
# ──────────────────────────────────────────────────────────────────
START_TIME=$(date +%s)

echo "Respaldo iniciado: $(date +'%Y-%m-%d %H:%M:%S')"
echo ""
{
    echo "────────────────────────────────────────"
    echo "Inicio: $(date +'%Y-%m-%d %H:%M:%S')"
    echo "Origen: $dir"
    echo "────────────────────────────────────────"
} >> "$LOG_FILE"

# ──────────────────────────────────────────────────────────────────
# 7. NUBE (rclone)
# ──────────────────────────────────────────────────────────────────
echo "[1] Google Drive"
CLOUD_STATUS=1

if ! rclone listremotes 2>/dev/null | grep -q "^gdrive:"; then
    echo "  Error: el remote 'gdrive:' no está configurado en rclone."
    echo "[$(date +"%F %T")] Error: remote 'gdrive:' no encontrado." >> "$LOG_FILE"
else
    if run_rclone; then
        CLOUD_STATUS=0
    fi
fi

if [[ $CLOUD_STATUS -eq 0 ]]; then
    echo "  Completado."
else
    echo "  Sin éxito."
fi

echo ""

# ──────────────────────────────────────────────────────────────────
# 8. SSD (rsync)
# ──────────────────────────────────────────────────────────────────
echo "[2] SSD Externo"
SSD_STATUS=2

if mountpoint -q "$ssd"; then
    ORIGIN_SIZE=$(timeout 30 du -sk --exclude=".git" "$dir" 2>/dev/null | awk '{print $1}') || ORIGIN_SIZE=0
    FREE_SPACE=$(df -k "$ssd" | awk 'NR==2 {print $4}')
    SAFE_SIZE=$(( ORIGIN_SIZE + ORIGIN_SIZE * MARGIN / 100 ))

    if (( FREE_SPACE < SAFE_SIZE )); then
        echo "  Error: espacio insuficiente en el SSD."
        echo "  Requerido: $((SAFE_SIZE/1024)) MB — Disponible: $((FREE_SPACE/1024)) MB"
        echo "[$(date +"%F %T")] Error: espacio insuficiente. Requerido: $((SAFE_SIZE/1024)) MB, Disponible: $((FREE_SPACE/1024)) MB." >> "$LOG_FILE"
        SSD_STATUS=1
    else
        SSD_STATUS=1
        for (( i=1; i<=RETRIES; i++ )); do
            (( i > 1 )) && echo "  Reintentando ($i/$RETRIES)..."
            if run_rsync; then
                SSD_STATUS=0
                break
            else
                (( i < RETRIES )) && sleep $SLEEP_RETRY
            fi
        done
    fi

    if [[ $SSD_STATUS -eq 0 ]]; then
        echo "  Completado."
    elif [[ $SSD_STATUS -eq 1 ]]; then
        echo "  Sin éxito."
    fi
else
    echo "  Omitido: SSD no detectado."
fi

echo ""

# ──────────────────────────────────────────────────────────────────
# 9. RESUMEN
# ──────────────────────────────────────────────────────────────────
END_TIME=$(date +%s)
DURATION=$(( END_TIME - START_TIME ))
(( DURATION >= 60 )) \
    && DURATION_STR="$(( DURATION/60 ))m $(( DURATION%60 ))s" \
    || DURATION_STR="${DURATION}s"

echo "[3] Resumen ($DURATION_STR)"

[[ $CLOUD_STATUS -eq 0 ]] \
    && echo "  Nube : Exitoso" \
    || echo "  Nube : Fallido"

case $SSD_STATUS in
    0) echo "  SSD  : Exitoso" ;;
    1) echo "  SSD  : Fallido" ;;
    2) echo "  SSD  : Omitido" ;;
esac

{
    echo "────────────────────────────────────────"
    echo "Fin: $(date +'%Y-%m-%d %H:%M:%S') ($DURATION_STR)"
    [[ $CLOUD_STATUS -eq 0 ]] && echo "Nube: OK" || echo "Nube: Fallida"
    case $SSD_STATUS in
        0) echo "SSD: OK" ;;
        1) echo "SSD: Fallido" ;;
        2) echo "SSD: Omitido" ;;
    esac
    echo "────────────────────────────────────────"
} >> "$LOG_FILE"

# ──────────────────────────────────────────────────────────────────
# 10. EXIT CODE
# ──────────────────────────────────────────────────────────────────
trap - EXIT INT TERM
rm -f "$LOCKFILE"

if [[ $CLOUD_STATUS -ne 0 ]] || [[ $SSD_STATUS -eq 1 ]]; then
    echo ""
    echo "Consulte el archivo de registro para obtener más detalles del error en:"
    echo "  $LOG_FILE"
    exit 1
fi

exit 0
