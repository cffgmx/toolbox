#!/bin/bash
# Nombre: sincronizar_10
# Perfil: Toolbox / Seguridad Industrial Máxima
set -eo pipefail

# ------------------------------------------------------------------
# 0. Configuración de entorno
# ------------------------------------------------------------------
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
LOCKFILE="$CACHE_DIR/sincronizar.lock"
LOG_FILE="$CACHE_DIR/sincronizar.log"
mkdir -p "$CACHE_DIR"

dir=$(xdg-user-dir DOCUMENTS 2>/dev/null || echo "$HOME/Documentos")
dir="${dir%/}/"
ssd="/media/$USER/Respaldo"
MARGIN=5  # % margen de seguridad en SSD
RETRIES=3
SLEEP_RETRY=5

# ------------------------------------------------------------------
# 1. Exclusividad (Lockfile)
# ------------------------------------------------------------------
exec 9>"$LOCKFILE"
if ! flock -n 9; then
    echo -e "\033[0;34m[INFO] Ya existe una sincronización en curso.\033[0m"
    exit 0
fi
trap 'rm -f "$LOCKFILE"' EXIT

# ------------------------------------------------------------------
# 2. Validación crítica del origen
# ------------------------------------------------------------------
if [[ ! -d "$dir" ]]; then
    echo -e "\033[0;31m[ERROR] Origen no encontrado: $dir\033[0m" | tee -a "$LOG_FILE"
    exit 1
fi
if [[ -z "$(find "$dir" -mindepth 1 -print -quit)" ]]; then
    echo -e "\033[0;31m[ERROR] Origen vacío. Abortando para proteger respaldo.\033[0m" | tee -a "$LOG_FILE"
    exit 1
fi

# ------------------------------------------------------------------
# 3. Respaldo en nube (rclone) con reintentos y logging
# ------------------------------------------------------------------
echo "== [1/2] Sincronizando con Google Drive ==" | tee -a "$LOG_FILE"
for i in $(seq 1 $RETRIES); do
    if rclone sync "$dir" "gdrive:ubuntu" --drive-use-trash --progress >>"$LOG_FILE" 2>&1; then
        echo -e "\033[0;32m✓ Nube actualizada correctamente.\033[0m" | tee -a "$LOG_FILE"
        CLOUD_STATUS=0
        break
    else
        echo -e "\033[1;33m[AVISO] Intento $i fallido de rclone. Reintentando en $SLEEP_RETRY s...\033[0m" | tee -a "$LOG_FILE"
        CLOUD_STATUS=1
        sleep $SLEEP_RETRY
    fi
done
[[ $CLOUD_STATUS -ne 0 ]] && echo -e "\033[1;33m[WARN] Fallaron todos los intentos de sincronización en la nube.\033[0m" | tee -a "$LOG_FILE"

# ------------------------------------------------------------------
# 4. Respaldo SSD con margen de seguridad y logging
# ------------------------------------------------------------------
echo -e "\n== [2/2] Sincronizando con SSD Externo ==" | tee -a "$LOG_FILE"
if mountpoint -q "$ssd"; then
    LOCAL_SIZE=$(du -sk "$dir" | awk '{print $1}')
    FREE_SPACE=$(df -k "$ssd" | awk 'NR==2 {print $4}')
    SAFE_SIZE=$(( LOCAL_SIZE + LOCAL_SIZE * MARGIN / 100 ))

    if [ "$FREE_SPACE" -lt "$SAFE_SIZE" ]; then
        echo -e "\033[1;33m[AVISO] Espacio insuficiente en SSD. Requerido: $((SAFE_SIZE/1024)) MB, Disponible: $((FREE_SPACE/1024)) MB\033[0m" | tee -a "$LOG_FILE"
        SSD_STATUS=1
    else
        if rsync -ah --delete --info=progress2 "$dir" "$ssd/" >>"$LOG_FILE" 2>&1; then
            echo -e "\033[0;32m✓ Respaldo en SSD finalizado con éxito.\033[0m" | tee -a "$LOG_FILE"
            SSD_STATUS=0
        else
            echo -e "\033[0;31m[ERROR] rsync encontró un problema durante la copia.\033[0m" | tee -a "$LOG_FILE"
            SSD_STATUS=1
        fi
    fi
else
    echo -e "\033[0;34m[INFO] SSD '$ssd' no detectado. Operación local omitida.\033[0m" | tee -a "$LOG_FILE"
    SSD_STATUS=2
fi

# ------------------------------------------------------------------
# 5. Resumen final
# ------------------------------------------------------------------
echo -e "\n=== Resumen de ejecución ===" | tee -a "$LOG_FILE"
echo "Origen: $dir" | tee -a "$LOG_FILE"
if [[ $CLOUD_STATUS -eq 0 ]]; then
    echo "✔ Nube: OK" | tee -a "$LOG_FILE"
else
    echo "⚠ Nube: Fallida" | tee -a "$LOG_FILE"
fi
case $SSD_STATUS in
    0) echo "✔ SSD: OK" | tee -a "$LOG_FILE" ;;
    1) echo "⚠ SSD: Problema detectado" | tee -a "$LOG_FILE" ;;
    2) echo "ℹ SSD: No conectado" | tee -a "$LOG_FILE" ;;
esac
echo "Fecha: $(date +'%F %T')" | tee -a "$LOG_FILE"
echo "=============================" | tee -a "$LOG_FILE"
