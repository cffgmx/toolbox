#!/bin/bash
# ==============================================================================
# Nombre: mantenimiento_universal
# Objetivo: Limpieza segura y no intrusiva para Debian/Ubuntu.
# ==============================================================================

set -euo pipefail

INFO='\033[0;34m'
EXITO='\033[0;32m'
AVISO='\033[0;33m'
NC='\033[0m'

# Función de ayuda para logs
log() { echo -e "${INFO}-->${NC} $1"; }

echo -e "${INFO}== Iniciando Mantenimiento Seguro ==${NC}"

# 1. Gestión de Paquetes
# Usamos apt-get para mayor estabilidad en scripts.
log "[1/5] Actualizando y saneando APT..."
sudo apt-get update
sudo apt-get upgrade -y
sudo apt-get autoremove --purge -y
sudo apt-get autoclean

# 2. Residuos de configuración
# El filtrado de paquetes 'rc' es seguro en ambas distros.
log "[2/5] Buscando residuos de paquetes (rc)..."
RC_PACKAGES=$(dpkg -l | awk '/^rc/{print $2}' | tr '\n' ' ')
if [[ -n "$RC_PACKAGES" ]]; then
    echo "$RC_PACKAGES" | xargs -r sudo dpkg --purge
else
    echo "Sin residuos de configuración."
fi

# 3. Journald
# 200MB es un punto medio seguro entre ahorro y capacidad de diagnóstico.
log "[3/5] Rotando logs del sistema..."
sudo journalctl --vacuum-size=200M --vacuum-time=1month

# 4. Capas Modernas (Detección pasiva)
if command -v snap >/dev/null 2>&1; then
    log "[4a/5] Configurando retención de Snap..."
    sudo snap set system refresh.retain=2
fi

if command -v flatpak >/dev/null 2>&1; then
    log "[4b/5] Limpiando Runtimes de Flatpak..."
    flatpak uninstall --unused -y
fi

# 5. Optimización SSD (TRIM)
# Verificación basada en el valor de descarte del dispositivo raíz.
log "[5/5] Verificando soporte TRIM..."
ROOT_DEV=$(findmnt -n -o SOURCE /)
if [[ $(lsblk -no DISC-MAX "$ROOT_DEV" | tr -d ' ') != "0B" ]]; then
    sudo fstrim -av
else
    echo -e "${AVISO}TRIM omitido:${NC} El hardware o la capa de cifrado no lo permiten."
fi

echo -e "\n${EXITO}== Mantenimiento finalizado con éxito. ==${NC}"
